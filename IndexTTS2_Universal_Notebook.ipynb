    print(f"   CUDA 版本: {torch.version.cuda}")
else:
    print("⚠️ 未检测到 GPU，将使用 CPU 模式 (极慢)")

# 安装 PyTorch
!pip install torch==2.8.0 torchaudio==2.8.0 --index-url https://download.pytorch.org/whl/cu121

