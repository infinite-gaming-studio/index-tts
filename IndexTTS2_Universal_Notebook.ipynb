# %% [markdown]
# ## 🚀 使用方式一: Python API

# %%
# 使用示例 1: 基础语音克隆
import os
os.chdir('/content/index-tts')

import sys
sys.path.insert(0, '/content/index-tts')

from indextts.infer_v2 import IndexTTS2
import torch

# 初始化模型 (使用 FP16 节省显存)
print("🔄 初始化 IndexTTS2 模型...")
tts = IndexTTS2(
    cfg_path="checkpoints/config.yaml",
    model_dir="checkpoints",
    use_fp16=True,  # 推荐: 节省显存
    use_deepspeed=False,  # T4 上不一定加速
    use_cuda_kernel=True,  # 启用 CUDA 优化
    device="cuda:0" if torch.cuda.is_available() else "cpu"
)
print("✅ 模型初始化完成！")

# %%
# 示例 1: 基础语音克隆
print("🎙️ 生成示例 1: 基础语音克隆...")

text = "你好，这是 IndexTTS2 的语音合成测试。声音自然流畅，支持中英文混合。"
output_path = "/content/output_basic.wav"

tts.infer(
    spk_audio_prompt='examples/voice_01.wav',  # 参考音频
    text=text,
    output_path=output_path,
    verbose=True
)

print(f"✅ 音频已保存: {output_path}")

# 播放音频
from IPython.display import Audio, display
display(Audio(output_path))

# %%
# 示例 2: 情感控制合成
print("🎭 生成示例 2: 情感控制...")

text = "这个消息太令人开心了！简直不敢相信！"
output_path = "/content/output_emotion.wav"

tts.infer(
    spk_audio_prompt='examples/voice_07.wav',
    text=text,
    output_path=output_path,
    emo_vector=[0.8, 0, 0, 0, 0, 0, 0.2, 0],  # 开心情绪
    verbose=True
)

print(f"✅ 音频已保存: {output_path}")
display(Audio(output_path))

# %%
# 示例 3: 使用文本描述控制情感
print("📝 生成示例 3: 文本情感描述...")

text = "你吓死我了！你是鬼吗？"
output_path = "/content/output_text_emo.wav"

tts.infer(
    spk_audio_prompt='examples/voice_12.wav',
    text=text,
    output_path=output_path,
    use_emo_text=True,
    emo_alpha=0.6,
    verbose=True
)

print(f"✅ 音频已保存: {output_path}")
display(Audio(output_path))

