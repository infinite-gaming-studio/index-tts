)
print("✅ 模型加载完成！")

# ==================== API 接口 ====================

@app.post("/api/tts")
async def text_to_speech(
    text: str = Form(..., description="要合成的文本"),
    spk_audio: UploadFile = File(..., description="参考音频文件 (音色克隆)"),
    emo_audio: UploadFile = File(None, description="情感参考音频 (可选)"),
    emo_vector: str = Form(None, description="情感向量 JSON 数组"),
    emo_alpha: float = Form(1.0, description="情感强度 0.0-1.0"),
    use_emo_text: bool = Form(False, description="是否使用文本情感描述"),
    emo_text: str = Form(None, description="情感文本描述"),
    use_random: bool = Form(False, description="是否启用随机性")
):
    """语音合成 API 接口"""
    try:
        # 保存上传的参考音频
        with NamedTemporaryFile(delete=False, suffix=".wav") as tmp_spk:
            shutil.copyfileobj(spk_audio.file, tmp_spk)
            spk_path = tmp_spk.name
        
        # 保存情感音频 (如果有)
        emo_path = None
        if emo_audio:
            with NamedTemporaryFile(delete=False, suffix=".wav") as tmp_emo:
                shutil.copyfileobj(emo_audio.file, tmp_emo)
                emo_path = tmp_emo.name
        
        # 解析情感向量
        emo_vec = None
        if emo_vector:
            emo_vec = json.loads(emo_vector)
        
        # 生成音频
        output_path = "/tmp/output_tts.wav"
        tts.infer(
            spk_audio_prompt=spk_path,
            text=text,
            output_path=output_path,
            emo_audio_prompt=emo_path,
            emo_vector=emo_vec,
            emo_alpha=emo_alpha,
            use_emo_text=use_emo_text,
            emo_text=emo_text,
            use_random=use_random,
            verbose=False
        )
        
        # 清理临时文件
        os.unlink(spk_path)
        if emo_path:
            os.unlink(emo_path)
        
        return FileResponse(output_path, media_type="audio/wav", filename="output.wav")
        
    except Exception as e:
        return JSONResponse(status_code=500, content={{"error": str(e)}})

@app.get("/api/health")
async def health_check():
    """健康检查接口"""
    return {{
        "status": "ok",
        "model": "IndexTTS2",
        "version": "2.0",
        "device": str(tts.device),
        "services": {{"api": True, "webui": "{DEPLOY_MODE}" in ["webui", "both"]}}
    }}

# ==================== WebUI (Gradio) ====================
if "{DEPLOY_MODE}" in ["webui", "both"]:
    import gradio as gr
    
    def gradio_tts(text, spk_audio, emo_audio=None, emo_alpha=1.0, use_emo_text=False):
        """Gradio 调用函数"""
        try:
            output_path = "/tmp/gradio_output.wav"
            tts.infer(
                spk_audio_prompt=spk_audio,
                text=text,
                output_path=output_path,
                emo_audio_prompt=emo_audio,
                emo_alpha=emo_alpha,
                use_emo_text=use_emo_text,
                verbose=False
            )
            return output_path
        except Exception as e:
            return str(e)
    
    # 创建 Gradio 界面
    with gr.Blocks(title="IndexTTS2") as demo:
        gr.Markdown("# 🎙️ IndexTTS2 语音合成")
        gr.Markdown("上传参考音频，输入文本，生成语音")
        
        with gr.Row():
            with gr.Column():
                text_input = gr.Textbox(label="输入文本", placeholder="请输入要合成的文本...")
                spk_audio_input = gr.Audio(label="参考音频 (音色)", type="filepath")
                emo_audio_input = gr.Audio(label="情感参考音频 (可选)", type="filepath")
                emo_alpha_slider = gr.Slider(0.0, 1.0, value=1.0, label="情感强度")
                use_emo_text_cb = gr.Checkbox(label="使用文本情感描述")
                submit_btn = gr.Button("生成语音", variant="primary")
            
            with gr.Column():
                audio_output = gr.Audio(label="生成的音频")
        
        submit_btn.click(
            fn=gradio_tts,
            inputs=[text_input, spk_audio_input, emo_audio_input, emo_alpha_slider, use_emo_text_cb],
            outputs=audio_output
        )
    
    # 挂载 Gradio 到 FastAPI (子路径 /ui)
    app = gr.mount_gradio_app(app, demo, path="/ui")
    print("✅ WebUI 已挂载到 /ui 路径")

