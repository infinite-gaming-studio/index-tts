# %% [markdown]
# ## 🧹 清理和释放资源

# %%
# 释放 GPU 显存
def cleanup():
    """清理 GPU 显存"""
    import gc
    import torch
    
    if torch.cuda.is_available():
        torch.cuda.empty_cache()
        torch.cuda.ipc_collect()
    gc.collect()
    print("🧹 资源清理完成！")

# 执行清理
cleanup()

# 显示最终显存状态
if torch.cuda.is_available():
    print(f"\n📊 清理后显存:")
    print(f"   已分配: {torch.cuda.memory_allocated() / 1e9:.2f} GB")
    print(f"   预留: {torch.cuda.memory_reserved() / 1e9:.2f} GB")

