# 检查服务是否启动
import requests
max_retries = 10
for i in range(max_retries):
    try:
        response = requests.get(f"http://localhost:{SERVICE_PORT}/api/health", timeout=5)
        if response.status_code == 200:
            print(f"✅ 服务已就绪！({i+1}/{max_retries})")
            break
    except:
        print(f"   等待服务启动... ({i+1}/{max_retries})")
        time.sleep(5)
else:
    print("⚠️ 服务启动超时，请检查日志")

# %%
# 启动 ngrok 内网穿透
print("🌐 启动 ngrok 内网穿透...")

try:
    # 断开已有的 ngrok 连接
    ngrok.kill()
    time.sleep(2)
    
    # 创建新的隧道
    public_url = ngrok.connect(SERVICE_PORT, "http")
    
    print(f"\n" + "="*60)
    print("✅ 服务部署成功！")
    print("="*60)
    print(f"\n🔗 公网访问地址: {public_url}")
    print(f"\n📚 可用端点:")
    print(f"   • 服务主页:    {public_url}/")
    print(f"   • API 文档:    {public_url}/docs")
    print(f"   • 健康检查:    {public_url}/api/health")
    print(f"   • 语音合成:    POST {public_url}/api/tts")
    
    if DEPLOY_MODE in ["webui", "both"]:
        print(f"   • WebUI 界面:  {public_url}/ui")
    
    print(f"\n📋 cURL 示例:")
    print(f"   curl -X POST {public_url}/api/tts \\\\")
    print(f"     -F \"text=你好世界\" \\\\")
    print(f"     -F \"spk_audio=@voice.wav\" \\\\")
    print(f"     --output output.wav")
    
    print(f"\n⚠️ 注意: ngrok 免费版每次重启会更换地址")
    print("="*60)
    
except Exception as e:
    print(f"❌ ngrok 启动失败: {e}")
    print("   请检查 ngrok token 是否正确设置")

