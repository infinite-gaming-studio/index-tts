# 导入 IndexTTS2
from indextts.infer_v2 import IndexTTS2

# 创建 FastAPI 应用
app = FastAPI(title="IndexTTS2 Service", description="IndexTTS2 语音合成服务 - API + WebUI")

# 初始化模型
print("🔄 加载 IndexTTS2 模型...")
