# %%
# Step 5: 部署服务 (API + WebUI)
print("🚀 部署服务...")

from pyngrok import ngrok

# ngrok token (从 https://dashboard.ngrok.com/get-started/your-authtoken 获取)
NGROK_TOKEN = None  # 替换为: "your_token_here"
if NGROK_TOKEN:
    ngrok.set_auth_token(NGROK_TOKEN)

# 服务配置
DEPLOY_MODE = "both"  # "api" | "webui" | "both"
PORT = 8000

# 创建服务脚本
service_code = f'''
import os, json, sys

# 读取配置
config = json.load(open("/tmp/notebook_config.json"))
work_dir = config["work_dir"]
os.chdir(f"{{work_dir}}/index-tts")
sys.path.insert(0, f"{{work_dir}}/index-tts")

from fastapi import FastAPI, File, UploadFile, Form
from fastapi.responses import FileResponse, JSONResponse, HTMLResponse
import torch, uvicorn, shutil, gradio as gr
from tempfile import NamedTemporaryFile
from indextts.infer_v2 import IndexTTS2

app = FastAPI(title="IndexTTS2")

# 加载模型
print("🔄 加载模型...")
tts = IndexTTS2(
    cfg_path="checkpoints/config.yaml",
    model_dir="checkpoints",
    use_fp16=True,
    device="cuda:0" if torch.cuda.is_available() else "cpu"
)
print("✅ 模型加载完成")

# API 接口
@app.post("/api/tts")
async def tts(
    text: str = Form(...),
    spk_audio: UploadFile = File(...),
    emo_alpha: float = Form(1.0)
):
    try:
        with NamedTemporaryFile(delete=False, suffix=".wav") as tmp:
            shutil.copyfileobj(spk_audio.file, tmp)
            spk_path = tmp.name
        
        output = "/tmp/out.wav"
        tts.infer(spk_audio_prompt=spk_path, text=text, output_path=output, emo_alpha=emo_alpha, verbose=False)
        os.unlink(spk_path)
        return FileResponse(output, media_type="audio/wav")
    except Exception as e:
        return JSONResponse(status_code=500, content={{"error": str(e)}})

@app.get("/api/health")
async def health():
    return {{"status": "ok", "model": "IndexTTS2", "device": str(tts.device)}}

# WebUI (如果启用)
if "{DEPLOY_MODE}" in ["webui", "both"]:
    def ui_tts(text, audio, alpha):
        out = "/tmp/ui_out.wav"
        tts.infer(spk_audio_prompt=audio, text=text, output_path=out, emo_alpha=alpha, verbose=False)
        return out
    
    with gr.Blocks(title="IndexTTS2") as demo:
        gr.Markdown("# 🎙️ IndexTTS2")
        with gr.Row():
            with gr.Column():
                txt = gr.Textbox(label="文本")
                aud = gr.Audio(label="参考音频", type="filepath")
                alpha = gr.Slider(0, 1, value=1, label="情感强度")
                btn = gr.Button("生成", variant="primary")
            with gr.Column():
                out = gr.Audio(label="结果")
        btn.click(ui_tts, [txt, aud, alpha], out)
    
    app = gr.mount_gradio_app(app, demo, path="/ui")

# 首页
@app.get("/")
async def root():
    return HTMLResponse(content="""
    <h1>🎙️ IndexTTS2 服务</h1>
    <p>API: <code>POST /api/tts</code> | WebUI: <a href="/ui">/ui</a> | Docs: <a href="/docs">/docs</a></p>
    """)

uvicorn.run(app, host="0.0.0.0", port={PORT})
'''

# 保存并启动
with open(f'{WORK_DIR}/index-tts/service.py', 'w') as f:
    f.write(service_code)

!pkill -f service.py 2>/dev/null; pkill -f ngrok 2>/dev/null
!nohup python {WORK_DIR}/index-tts/service.py > service.log 2>&1 &

import time
time.sleep(30)

# 启动 ngrok
try:
    public_url = ngrok.connect(PORT, "http")
    print(f"\n{'='*60}")
    print("✅ 服务启动成功！")
    print(f"{'='*60}")
    print(f"🔗 公网地址: {public_url}")
    print(f"📚 API: {public_url}/api/tts")
    if DEPLOY_MODE in ["webui", "both"]:
        print(f"🌐 WebUI: {public_url}/ui")
    print(f"📖 文档: {public_url}/docs")
    print(f"\n💡 示例:")
    print(f'  curl -X POST {public_url}/api/tts -F "text=你好" -F "spk_audio=@voice.wav" --output out.wav')
    print(f"{'='*60}")
except Exception as e:
    print(f"❌ ngrok 启动失败: {e}")

# 显示日志
!tail -n 20 service.log

