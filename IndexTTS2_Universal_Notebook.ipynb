# %% [markdown]
# # 🎙️ IndexTTS2 通用部署 Notebook
# 
# 本脚本支持在云端 Notebook 环境 (Google Colab / Kaggle) 上自动部署 IndexTTS2 模型
# 
# ## 特性:
# - ✅ 自动检测运行平台
# - ✅ 智能安装 Conda/Mamba 环境
# - ✅ FP16 模式节省显存 (适合 T4/P100)
# - ✅ 支持 HuggingFace/ModelScope 模型下载
# - ✅ 提供 WebUI 和 API 两种使用方式

# %%
# Step 1: 检测运行平台并安装基础环境
import os
import sys

# 检测平台
IN_COLAB = 'google.colab' in sys.modules
IN_KAGGLE = os.path.exists('/kaggle/input') or os.environ.get('KAGGLE_KERNEL_RUN_TYPE') is not None

print(f"🔍 检测到运行平台:")
print(f"   Google Colab: {IN_COLAB}")
print(f"   Kaggle: {IN_KAGGLE}")

# 根据平台安装 Conda/Mamba
if IN_COLAB:
    print("\n📦 为 Colab 安装 Mamba 环境...")
    !pip install -q condacolab
    import condacolab
    condacolab.install()
    # 注意: 安装后会自动重启 kernel，需要重新运行后续步骤
    print("✅ Colab 环境安装完成！请继续执行 Step 2")
    
elif IN_KAGGLE:
    print("\n📦 Kaggle 已内置 Conda，无需额外安装")
    !conda --version
    print("✅ Kaggle 环境检查完成！请继续执行 Step 2")
    
else:
    print("\n⚠️ 未知平台，假设已安装 Conda/Mamba")

# %%
# Step 2: 配置 Python 和 CUDA 环境
print("🐍 配置 Python 3.10 环境...")

# 安装 Python 3.10 (如果当前不是)
!mamba install -y python=3.10 -c conda-forge

# 安装 CUDA 工具包
print("⚙️ 安装 CUDA 工具包...")
!mamba install -y cudatoolkit=11.8 -c nvidia || echo "CUDA 可能已安装或跳过"

# 验证 Python 版本
import sys
print(f"\n✅ Python 版本: {sys.version}")

